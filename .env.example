
# FastAPI Security
API_KEY=your_secure_api_key_here

# Instagram Credentials
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=
PROXY_URL=http://user:pass@host:port

# Google Sheets
GOOGLE_SHEETS_ID=
GOOGLE_APPLICATION_CREDENTIALS=/app/credentials.json

# Outreach Engine Config
DAILY_MESSAGE_LIMIT=20
MIN_DELAY_SECONDS=60
MAX_DELAY_SECONDS=300
POLLING_INTERVAL_MINUTES=30
SESSION_FILE_PATH=/app/sessions/session.json

SESSION_ENCRYPTION_KEY=kX9..._

PROXY_CHECK_INTERVAL = 60  # секунд між перевірками
PROXY_CHECK_TIMEOUT = 10  # секунд на один запит
PROXY_MAX_FAILURES = 2  # скільки провалів підряд = проксі мертвий